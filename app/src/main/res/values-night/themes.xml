<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BibleApp" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/indigo_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/indigo</item>
        <item name="colorSecondary">@color/gold</item>
        <item name="android:statusBarColor">@color/indigo_dark</item>
        <item name="android:navigationBarColor">@color/indigo_dark</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogPositiveBtn</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogNegativeBtn</item>
    </style>
    <style name="DialogPositiveBtn" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">#C2A870</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="DialogNegativeBtn" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">#7E9BB5</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/white</item>
    </style>
</resources>
