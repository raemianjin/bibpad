<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1020">

    <!-- 상단 바: 닫기 + 공유 -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btn_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="✕"
            android:textSize="20sp"
            android:textColor="#AAB0C5"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="메모 장표"
            android:textSize="15sp"
            android:textColor="#AAB0C5"
            android:gravity="center"/>

        <TextView
            android:id="@+id/btn_share"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="공유"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/gold_soft"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground"/>
    </LinearLayout>

    <!-- 템플릿 선택 칩 바 -->
    <HorizontalScrollView
        android:id="@+id/template_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/template_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <!-- 스크롤 가능한 장표 미리보기 영역 -->
    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/template_scroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 카드가 코드로 삽입되는 호스트 (태블릿에서 가운데 정렬) -->
        <LinearLayout
            android:id="@+id/preview_host"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"/>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
